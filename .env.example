# Copy this to .env and fill in your values
# Get a free Groq API key at: https://console.groq.com

# ── Required ────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
JWT_SECRET_KEY=super-secret-jwt-key-for-development-change-in-production

# ── Database ─────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/askmydocs
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/askmydocs
# ── Optional overrides ────────────────────────────────────────
# GROQ_MODEL=llama3-70b-8192
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# CHROMA_PERSIST_DIR=./chroma_db
# DEBUG=true

# ── Eval thresholds ───────────────────────────────────────────
# MIN_FAITHFULNESS=0.80
# MIN_ANSWER_RELEVANCY=0.75
# MIN_CONTEXT_RECALL=0.70

# ── RAGAS needs an OpenAI key for its own scoring LLM ─────────
# (Only needed when running: pytest tests/test_eval.py)
OPENAI_API_KEY=your_openai_api_key_here
